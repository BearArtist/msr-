<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <RootNamespace>MsrDrv</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <Platform>x64</Platform>
    <Configuration>Release</Configuration>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>KMDF</DriverType>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <DebuggerFlavor>Dbgeng</DebuggerFlavor>
    <KmdfVersionMajor>1</KmdfVersionMajor>
    <KmdfVersionMinor>15</KmdfVersionMinor>
  </PropertyGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <PreprocessorDefinitions>NTDDI_VERSION=0x0A000000;_NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>true</TreatWarningAsError>
      <BufferSecurityCheck>false</BufferSecurityCheck>
    </ClCompile>
    <Link>
      <AdditionalDependencies>%(AdditionalDependencies);ntoskrnl.lib;hal.lib;WdfLdr.lib;WdfDriverEntry.lib</AdditionalDependencies>
      <EntryPoint>DriverEntry</EntryPoint>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="msr_drv.c" />
  </ItemGroup>

  <ItemGroup>
    <Inf Include="msr_drv.inf" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <Import Project="$(WDKContentPath)\WindowsDriver.Default.props" Condition="Exists('$(WDKContentPath)\WindowsDriver.Default.props')" />
  <Import Project="$(WDKContentPath)\.props" Condition="Exists('$(WDKContentPath)\.props')" />
</Project>
